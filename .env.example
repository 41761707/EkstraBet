# ================================
# DATABASE (REQUIRED)
# ================================
DB_HOST=localhost
DB_USER=guestuser
DB_PASSWORD=your_database_password
DB_NAME=ekstrabet
DB_PORT=3306

# ================================
# API
# ================================
API_TITLE=EkstraBet API
API_DESCRIPTION=EkstraBet API for managing sports data
API_VERSION=1.0.0

# ================================
# SERVER
# ================================
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ================================
# PAGINATION
# ================================
DEFAULT_PAGE_SIZE=50
MAX_PAGE_SIZE=500

# ================================
# LOGGING
# ================================
LOG_LEVEL=INFO

# ================================
# CORS
# ================================
FRONTEND_ORIGIN=http://localhost:3000
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
CORS_METHODS=["GET","POST","PUT","DELETE"]

# ================================
# AUTHENTICATION (REQUIRED)
# ================================
SECRET_KEY=generate_a_strong_random_key_at_least_32_chars
ACCESS_TOKEN_EXPIRE_MINUTES=1440
AUTH_ENABLED=true
AUTH_COOKIE_NAME=ekstrabet_token

# ================================
# CACHE
# ================================
CACHE_TTL=300
ENABLE_CACHE=false
