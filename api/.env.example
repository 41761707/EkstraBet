# Przykładowy plik konfiguracji środowiskowej dla API EkstraBet
# Skopiuj ten plik jako .env i dostosuj wartości do swojego środowiska

# UWAGA: Ten plik zawiera przykładowe wartości. Nigdy nie commituj pliku .env z prawdziwymi hasłami!

# ================================
# USTAWIENIA BAZY DANYCH (WYMAGANE)
# ================================
DB_HOST=localhost
DB_USER=guestuser
DB_PASSWORD=twoje_haslo_do_bazy_danych
DB_NAME=ekstrabet
DB_PORT=3306

# ================================
# USTAWIENIA API
# ================================
API_TITLE=EkstraBet API
API_DESCRIPTION=Kompleksowe API systemu EkstraBet do zarządzania danymi sportowymi
API_VERSION=1.0.0

# ================================
# USTAWIENIA SERWERA
# ================================
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ================================
# USTAWIENIA PAGINACJI
# ================================
DEFAULT_PAGE_SIZE=50
MAX_PAGE_SIZE=500

# ================================
# USTAWIENIA LOGOWANIA
# ================================
LOG_LEVEL=INFO

# ================================
# USTAWIENIA CORS
# ================================
CORS_ORIGINS=["*"]

# ================================
# USTAWIENIA UWIERZYTELNIANIA (WYMAGANE)
# ================================
# Wygeneruj silny, losowy klucz (co najmniej 32 znaki)
# Przykład: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=wygeneruj_silny_losowy_klucz_co_najmniej_32_znaki
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ================================
# USTAWIENIA CACHE (NA PRZYSZŁOŚĆ)
# ================================
CACHE_TTL=300
ENABLE_CACHE=false