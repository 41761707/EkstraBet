{
  "model_name": "FOOTBALL_GOALS_POISSON_V1",
  "model_version": "1.0.0",
  "task_type": "goals_poisson",
  "window_size": 8,
  "sequence_feature_columns": [
    "result_points",
    "goals_for",
    "goals_against",
    "xg_for",
    "xg_against",
    "shots",
    "shots_on_goal",
    "possession",
    "elo_before",
    "gap_attack_before",
    "gap_defense_before",
    "is_home",
    "btts",
    "total_goals"
  ],
  "static_feature_columns": [
    "elo_home",
    "elo_away",
    "elo_diff",
    "home_attack",
    "home_defense",
    "away_attack",
    "away_defense",
    "home_attack_away_defense",
    "away_attack_home_defense",
    "home_czech_win_rate",
    "away_czech_win_rate",
    "league_avg_goals",
    "league_btts_rate",
    "league_over_25_rate",
    "h2h_home_win_rate",
    "h2h_draw_rate",
    "home_rest_days",
    "away_rest_days",
    "rest_days_diff",
    "league_tier"
  ],
  "output": [
    "lambda_home",
    "lambda_away"
  ],
  "loss": "independent_poisson_nll"
}