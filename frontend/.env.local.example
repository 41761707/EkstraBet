NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# Must match backend AUTH_ENABLED (server-side only — not NEXT_PUBLIC_)
AUTH_ENABLED=true
AUTH_COOKIE_NAME=ekstrabet_token
# FastAPI base URL used by BFF routes / proxy (server-side)
API_BASE_URL=http://localhost:8000

# Chat provider switch: openrouter (production) | cursor (prototype)
CHAT_PROVIDER=openrouter
NEXT_PUBLIC_CHAT_DEFAULT_PROVIDER=openrouter
# Set to true only for internal debugging of Cursor SDK prototype
CHAT_ENABLE_CURSOR=false
NEXT_PUBLIC_CHAT_ENABLE_CURSOR=false

# Rate limit: in-memory per Node process (NOT shared across workers/replicas).
# Prefer session cookie key; IP fallback; ip:unknown shares one bucket.
# For multi-instance production, replace with a shared store (e.g. Redis).
CHAT_RATE_LIMIT_WINDOW_MS=60000
CHAT_RATE_LIMIT_MAX_REQUESTS=20

# Production OpenRouter
OPENROUTER_API_KEY=sk-or-v1-xxx
OPENROUTER_MODEL=openai/gpt-4o-mini
# Optional OpenRouter attribution headers
# OPENROUTER_HTTP_REFERER=https://ekstrabet.example
# OPENROUTER_APP_TITLE=EkstraBet Chat

# Local Cursor SDK prototype (local runtime on the server machine)
CURSOR_API_KEY=cursor_xxx
CURSOR_MODEL=composer-2.5
